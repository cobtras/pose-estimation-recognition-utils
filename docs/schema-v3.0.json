{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pose Estimation Recognition Utils v3.0",
  "description": "Schema for 3D skeleton data with topology, kinematics, and bone vectors.",
  "type": "object",
  "required": ["origin"],
  "properties": {
    "origin": { "type": "string" },
    "HumanDetectionModel": { "type": "string" },
    "PoseEstimationModel": { "type": "string" },
    "Pose3DGenerationMethod": { "type": "string" },
    "3DLiftingModel": { "type": "string" },
    "BoundingBox": { "$ref": "#/definitions/boundingBox" },
    "person_id": { "type": "integer" },
    "graph": { "$ref": "#/definitions/graph" },
    "skeletonpoints": { "$ref": "#/definitions/skeletonPoints" },
    "bone_vectors": {
      "type": "array",
      "items": { "$ref": "#/definitions/boneVector" }
    },
    "persons": {
      "type": "array",
      "items": { "$ref": "#/definitions/person" }
    },
    "frames": {
      "type": "array",
      "items": { "$ref": "#/definitions/frame" }
    }
  },
  "definitions": {
    "point": {
      "type": "object",
      "required": ["id", "x", "y"],
      "properties": {
        "id": { "type": "integer" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" },
        "name": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "velocity": { "type": "number" },
        "velocity_x": { "type": "number" },
        "velocity_y": { "type": "number" },
        "velocity_z": { "type": "number" },
        "acceleration": { "type": "number" },
        "acceleration_x": { "type": "number" },
        "acceleration_y": { "type": "number" },
        "acceleration_z": { "type": "number" }
      }
    },
    "skeletonPoints": {
      "type": "array",
      "items": { "$ref": "#/definitions/point" }
    },
    "boundingBox": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4,
      "description": "[x_min, y_min, width, height]"
    },
    "graph": {
      "type": "object",
      "required": ["edges"],
      "properties": {
        "edges": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 2,
            "maxItems": 2
          }
        },
        "edge_types": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "boneVector": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "integer" },
        "end": { "type": "integer" },
        "x": { "type": ["number", "null"] },
        "y": { "type": ["number", "null"] },
        "z": { "type": ["number", "null"] },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    },
    "person": {
      "type": "object",
      "properties": {
        "person_id": { "type": "integer" },
        "BoundingBox": { "$ref": "#/definitions/boundingBox" },
        "skeletonpoints": { "$ref": "#/definitions/skeletonPoints" },
        "bone_vectors": {
          "type": "array",
          "items": { "$ref": "#/definitions/boneVector" }
        },
        "graph": { "$ref": "#/definitions/graph" }
      }
    },
    "frame": {
      "type": "object",
      "required": ["frame"],
      "properties": {
        "frame": { "type": "integer" },
        "skeletonpoints": { "$ref": "#/definitions/skeletonPoints" },
        "bone_vectors": {
          "type": "array",
          "items": { "$ref": "#/definitions/boneVector" }
        },
        "persons": {
          "type": "array",
          "items": { "$ref": "#/definitions/person" }
        }
      }
    }
  }
}

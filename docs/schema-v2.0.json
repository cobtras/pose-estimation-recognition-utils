{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pose Estimation Recognition Utils v2.0",
  "description": "Schema for 3D skeleton data (Image and Video, Single and Multi-Person)",
  "type": "object",
  "required": ["origin"],
  "properties": {
    "origin": { "type": "string" },
    "HumanDetectionModel": { "type": "string" },
    "PoseEstimationModel": { "type": "string" },
    "Pose3DGenerationMethod": { "type": "string" },
    "3DLiftingModel": { "type": "string" },
    "BoundingBox": { "$ref": "#/definitions/boundingBox" },
    "person_id": { "type": "integer" },
    "skeletonpoints": { "$ref": "#/definitions/skeletonPoints" },
    "persons": {
      "type": "array",
      "items": { "$ref": "#/definitions/person" }
    },
    "frames": {
      "type": "array",
      "items": { "$ref": "#/definitions/frame" }
    }
  },
  "definitions": {
    "point": {
      "type": "object",
      "required": ["id", "x", "y", "z"],
      "properties": {
        "id": { "type": "integer" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" },
        "name": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "skeletonPoints": {
      "type": "array",
      "items": { "$ref": "#/definitions/point" }
    },
    "boundingBox": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4,
      "description": "[x_min, y_min, width, height]"
    },
    "person": {
      "type": "object",
      "required": ["skeletonpoints"],
      "properties": {
        "person_id": { "type": "integer" },
        "BoundingBox": { "$ref": "#/definitions/boundingBox" },
        "skeletonpoints": { "$ref": "#/definitions/skeletonPoints" }
      }
    },
    "frame": {
      "type": "object",
      "required": ["frame"],
      "properties": {
        "frame": { "type": "integer" },
        "skeletonpoints": { "$ref": "#/definitions/skeletonPoints" },
        "persons": {
          "type": "array",
          "items": { "$ref": "#/definitions/person" }
        }
      }
    }
  }
}
